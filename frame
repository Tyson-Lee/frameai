#!/usr/bin/env python3
"""frame — FrameAI command-line interface.

FrameAI turns a natural-language description of a repetitive task into a
reusable Claude Code skill. Each `frame add` produces:

  - skills/<slug>/SKILL.md          # the new slash-command anyone can invoke
  - skills/<slug>/helpers/          # generated supporting code, if any
  - automations/<slug>/README.md    # human-facing usage guide
  - automations/<slug>/input.md     # the original natural-language description
  - automations/<slug>/before_after.md
  - automations/<slug>/runs/        # per-invocation archive (created on each run)

`frame run <slug> [--in FILE]... [--image FILE]... [args...]` invokes the
skill via Claude Code's headless mode and archives the run.

`frame refine <slug> "<change description>"` asks the AI team to evolve the
skill — preserving its name + interface, adding/changing behavior.

The CLI is intentionally small (~300 LOC) — the heavy lifting lives in
the kit's agents, skills, scripts, and hooks. See README.md for the full
pipeline picture.
"""

from __future__ import annotations

import argparse
import re
import shutil
import subprocess
import sys
from datetime import datetime, timezone
from pathlib import Path

ROOT = Path(__file__).resolve().parent
AUTOMATIONS = ROOT / "automations"
SKILLS = ROOT / "skills"

# -----------------------------------------------------------------------------
# Prompts dispatched to claude --print
# -----------------------------------------------------------------------------

ADD_PROMPT = """\
You are FrameAI's autonomous build pipeline. The user has described a
repetitive task they want to automate. Your job is to build a reusable
Claude Code skill that any teammate can invoke later.

Run the kit's pipeline end-to-end without further prompting:
  1. /prd {input_path}             — turn the description into a PRD
  2. /kickoff                      — produce requirements + architecture + issues
  3. /sprint                       — execute each issue (worktree-isolated)
  4. /ship                         — finalize the artifacts

The deliverable is **a new skill**, not a one-shot script. Specifically:

  - Create `skills/{slug}/SKILL.md.tmpl` declaring inputs, outputs, and steps.
    The skill MUST accept these environment variables / arguments at runtime:
        $FRAMEAI_RUN_INPUTS   absolute path to a directory of input files
        $FRAMEAI_RUN_OUTPUTS  absolute path to a directory the skill MUST
                              write its outputs into
        $FRAMEAI_RUN_TEXT     free-form text arguments from the caller
    The skill itself only `Read`s from $FRAMEAI_RUN_INPUTS and only `Write`s
    into $FRAMEAI_RUN_OUTPUTS. No writes outside that directory.
  - Add `skills/{slug}/helpers/` for any deterministic Python/Bash helpers
    that should NOT live inside the SKILL prompt (e.g. PDF parsing, table
    formatting, API clients).
  - Run `python3 scripts/gen_skills.py` so `skills/{slug}/SKILL.md` is
    generated alongside the template.
  - Write `automations/{slug}/README.md` documenting:
      - one-line purpose
      - example invocation (`frame run {slug} --in foo.pdf "<text>"`)
      - what inputs are required vs optional
      - what outputs will appear under `runs/<ts>/outputs/`
      - any Limits / honest framing
  - Write `automations/{slug}/before_after.md` with the user's estimated
    original-task time vs. the automation's expected runtime.

The user's description is in {input_path}. Do not ask follow-up questions
unless an ambiguity blocks structural work. Where reasonable defaults exist,
apply them and note the assumption inline.

Target directory for the skill's runtime outputs (NOT for build artifacts):
  $FRAMEAI_RUN_OUTPUTS / runs/<timestamp>/outputs/   (set per-run by frame CLI)
"""

REFINE_PROMPT = """\
You are FrameAI's autonomous refinement pipeline. The user wants to evolve
an existing skill without changing its name or external interface.

Existing skill: skills/{slug}/SKILL.md(.tmpl)
Refinement request follows.

Steps:
  1. Read the existing skill and its helpers.
  2. Apply the refinement, preserving:
       - skill name (still `{slug}` after the change)
       - input/output contract documented in the SKILL frontmatter (UNLESS
         the user explicitly asks to change it)
       - existing `runs/` archive directory layout (do NOT rewrite history)
  3. Update `automations/{slug}/README.md` to reflect the change.
  4. Append a changelog entry to `automations/{slug}/CHANGELOG.md`
     (create the file if absent).
  5. Run `python3 scripts/gen_skills.py` then `python3 -m pytest -q` to
     confirm nothing regressed.

Refinement request:
{refinement}
"""

# -----------------------------------------------------------------------------
# Helpers
# -----------------------------------------------------------------------------


def slugify(text: str) -> str:
    s = re.sub(r"[^a-z0-9]+", "-", text.lower()).strip("-")
    return (s[:60] or "automation").strip("-")


def timestamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H-%M-%S")


def find_claude() -> str | None:
    return shutil.which("claude")


def write_input_md(target: Path, description: str) -> Path:
    input_path = target / "input.md"
    input_path.write_text(
        f"# Automation input\n\n"
        f"_Created: {datetime.now(timezone.utc).isoformat(timespec='seconds')}_\n\n"
        f"## User description\n\n{description}\n",
        encoding="utf-8",
    )
    return input_path


# -----------------------------------------------------------------------------
# Commands
# -----------------------------------------------------------------------------


def cmd_add(args: argparse.Namespace) -> int:
    description = args.description.strip()
    if not description:
        print("frame add: description must be non-empty", file=sys.stderr)
        return 2

    slug = args.slug or slugify(description)
    auto_dir = AUTOMATIONS / slug
    skill_dir = SKILLS / slug

    if (auto_dir.exists() or skill_dir.exists()) and not args.force:
        print(
            f"frame add: skills/{slug}/ or automations/{slug}/ already exists. "
            f"Use --slug to choose a different name or --force to overwrite.",
            file=sys.stderr,
        )
        return 2

    auto_dir.mkdir(parents=True, exist_ok=True)
    input_path = write_input_md(auto_dir, description)
    prompt = ADD_PROMPT.format(
        slug=slug,
        input_path=input_path.relative_to(ROOT),
    )

    print(f"FrameAI: scaffolded automations/{slug}/")
    print(f"FrameAI: dispatching Claude Code (headless build pipeline)…")
    print()

    if args.dry_run:
        print("--- prompt (--dry-run) ---")
        print(prompt)
        return 0

    if find_claude() is None:
        print(
            "FrameAI: `claude` CLI not found on PATH. Install Claude Code first.",
            file=sys.stderr,
        )
        return 3

    return subprocess.run(["claude", "--print", prompt], cwd=ROOT).returncode


def cmd_list(_args: argparse.Namespace) -> int:
    if not AUTOMATIONS.exists():
        print("No automations yet. Run: frame add \"<description>\"")
        return 0
    rows: list[tuple[str, str, int]] = []
    for d in sorted(AUTOMATIONS.iterdir()):
        if not d.is_dir():
            continue
        skill = SKILLS / d.name / "SKILL.md"
        runs_dir = d / "runs"
        run_count = (
            len([r for r in runs_dir.iterdir() if r.is_dir()])
            if runs_dir.exists()
            else 0
        )
        if skill.exists():
            status = "ready"
        elif (d / "input.md").exists():
            status = "draft"
        else:
            status = "empty"
        rows.append((d.name, status, run_count))
    if not rows:
        print("No automations yet. Run: frame add \"<description>\"")
        return 0
    width_name = max(len(n) for n, _, _ in rows)
    print(f"  {'NAME':<{width_name}}  STATUS  RUNS")
    for name, status, runs in rows:
        print(f"  {name:<{width_name}}  {status:<6}  {runs}")
    return 0


def cmd_run(args: argparse.Namespace) -> int:
    slug = args.name
    skill = SKILLS / slug / "SKILL.md"
    if not skill.is_file():
        print(
            f"frame run: skills/{slug}/SKILL.md not found. "
            f"Build first with: frame add \"<description>\"",
            file=sys.stderr,
        )
        return 2

    auto_dir = AUTOMATIONS / slug
    auto_dir.mkdir(parents=True, exist_ok=True)
    run_dir = auto_dir / "runs" / timestamp()
    inputs_dir = run_dir / "inputs"
    outputs_dir = run_dir / "outputs"
    inputs_dir.mkdir(parents=True, exist_ok=True)
    outputs_dir.mkdir(parents=True, exist_ok=True)

    # Copy file inputs (--in) and image inputs (--image) into runs/<ts>/inputs/
    copied: list[tuple[Path, str]] = []  # (target_path, role)
    for src in (args.input or []):
        srcp = Path(src).expanduser().resolve()
        if not srcp.is_file():
            print(f"frame run: input file not found: {src}", file=sys.stderr)
            return 2
        dst = inputs_dir / srcp.name
        shutil.copy2(srcp, dst)
        copied.append((dst, "file"))
    for src in (args.image or []):
        srcp = Path(src).expanduser().resolve()
        if not srcp.is_file():
            print(f"frame run: image file not found: {src}", file=sys.stderr)
            return 2
        dst = inputs_dir / srcp.name
        shutil.copy2(srcp, dst)
        copied.append((dst, "image"))

    text_arg = " ".join(args.rest) if args.rest else ""

    inputs_summary = (
        "\n".join(f"  - {role}: {p.relative_to(ROOT)}" for p, role in copied)
        or "  (no file inputs)"
    )

    prompt_lines = [
        f"Invoke the `{slug}` skill (skills/{slug}/SKILL.md).",
        "",
        "Inputs:",
        inputs_summary,
        "",
        f"Text arguments: {text_arg or '(none)'}",
        "",
        f"Write ALL outputs under: {outputs_dir.relative_to(ROOT)}",
        f"Do NOT write outside that directory.",
        f"Inputs are at: {inputs_dir.relative_to(ROOT)}",
        "",
        "Execute the skill end-to-end without follow-up questions where "
        "reasonable defaults exist. After completion, list every file you "
        "wrote (one per line, relative to repo root).",
    ]
    prompt = "\n".join(prompt_lines)

    log_path = run_dir / "log.txt"
    prompt_path = run_dir / "prompt.txt"
    prompt_path.write_text(prompt, encoding="utf-8")

    print(f"FrameAI: starting run → {run_dir.relative_to(ROOT)}/")
    print(f"FrameAI: dispatching Claude Code…")

    if args.dry_run:
        print("--- prompt (--dry-run) ---")
        print(prompt)
        return 0

    if find_claude() is None:
        print(
            "FrameAI: `claude` CLI not found on PATH. Install Claude Code first.",
            file=sys.stderr,
        )
        return 3

    env_intro = (
        f"FRAMEAI_RUN_INPUTS={inputs_dir}\n"
        f"FRAMEAI_RUN_OUTPUTS={outputs_dir}\n"
        f"FRAMEAI_RUN_TEXT={text_arg!r}\n"
    )
    log_path.write_text(env_intro + "\n--- claude --print stdout ---\n", encoding="utf-8")

    with log_path.open("a", encoding="utf-8") as logf:
        proc = subprocess.run(
            ["claude", "--print", prompt],
            cwd=ROOT,
            stdout=logf,
            stderr=subprocess.STDOUT,
        )

    listed_outputs = sorted(outputs_dir.rglob("*"))
    listed_outputs = [p for p in listed_outputs if p.is_file()]
    print()
    if listed_outputs:
        print(f"FrameAI: {len(listed_outputs)} output file(s):")
        for p in listed_outputs:
            print(f"  - {p.relative_to(ROOT)}")
    else:
        print(
            f"FrameAI: no output files were written under {outputs_dir.relative_to(ROOT)}. "
            f"Check log: {log_path.relative_to(ROOT)}"
        )
    return proc.returncode


def cmd_refine(args: argparse.Namespace) -> int:
    slug = args.name
    skill = SKILLS / slug / "SKILL.md"
    if not skill.is_file():
        print(
            f"frame refine: skills/{slug}/SKILL.md not found. "
            f"Build first with: frame add \"<description>\"",
            file=sys.stderr,
        )
        return 2

    refinement = args.refinement.strip()
    if not refinement:
        print("frame refine: refinement description must be non-empty", file=sys.stderr)
        return 2

    prompt = REFINE_PROMPT.format(slug=slug, refinement=refinement)

    print(f"FrameAI: refining skills/{slug}/…")
    if args.dry_run:
        print("--- prompt (--dry-run) ---")
        print(prompt)
        return 0

    if find_claude() is None:
        print(
            "FrameAI: `claude` CLI not found on PATH. Install Claude Code first.",
            file=sys.stderr,
        )
        return 3

    return subprocess.run(["claude", "--print", prompt], cwd=ROOT).returncode


def cmd_update(args: argparse.Namespace) -> int:
    """Pull the latest skills/agents from the remote and re-run setup."""
    # 1. Safety: refuse if local working tree has uncommitted changes
    status = subprocess.run(
        ["git", "status", "--porcelain"],
        cwd=ROOT,
        capture_output=True,
        text=True,
    )
    if status.returncode != 0:
        print("frame update: not a git repository.", file=sys.stderr)
        return 2
    if status.stdout.strip() and not args.force:
        print(
            "frame update: refusing — working tree has uncommitted changes:\n"
            f"{status.stdout}"
            "Commit, stash, or rerun with --force to discard.",
            file=sys.stderr,
        )
        return 2

    # 2. Snapshot what's installed before pull
    skills_before = {p.name for p in SKILLS.iterdir() if p.is_dir()}

    # 3. git pull
    if args.dry_run:
        print("(dry-run) would run: git pull --ff-only origin main")
    else:
        pull = subprocess.run(
            ["git", "pull", "--ff-only", "origin", "main"],
            cwd=ROOT,
        )
        if pull.returncode != 0:
            print(
                "frame update: git pull failed. Resolve manually and re-run.",
                file=sys.stderr,
            )
            return pull.returncode

    # 4. Re-run setup.sh if present (idempotent)
    setup = ROOT / "setup.sh"
    if setup.is_file() and not args.dry_run:
        subprocess.run(["bash", str(setup)], cwd=ROOT, check=False)

    # 5. Print delta
    if not args.dry_run:
        skills_after = {p.name for p in SKILLS.iterdir() if p.is_dir()}
        added = sorted(skills_after - skills_before)
        removed = sorted(skills_before - skills_after)
        if added or removed:
            print()
            print("Skill changes:")
            for s in added:
                print(f"  + {s}")
            for s in removed:
                print(f"  - {s}")
        else:
            print()
            print("No skill additions or removals in this update.")
    return 0


def cmd_share(args: argparse.Namespace) -> int:
    slug = args.name
    paths = [AUTOMATIONS / slug, SKILLS / slug]
    if not any(p.exists() for p in paths):
        print(f"frame share: no such automation {slug!r}", file=sys.stderr)
        return 2
    for p in paths:
        if p.exists():
            subprocess.run(["git", "add", str(p.relative_to(ROOT))], cwd=ROOT, check=True)
    msg = args.message or f"feat(automations): add {slug}"
    subprocess.run(["git", "commit", "-m", msg], cwd=ROOT, check=True)
    print(f"FrameAI: committed skills/{slug}/ + automations/{slug}/")
    print("Push with: git push  (after `git remote add origin ...`)")
    return 0


# -----------------------------------------------------------------------------
# CLI surface
# -----------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="frame",
        description="FrameAI — automation of automation. "
        "Describe a repetitive task; AI plans, builds, tests, and documents it "
        "as a reusable Claude Code skill anyone can invoke.",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    a = sub.add_parser(
        "add",
        help="Build a new automation skill from a natural-language description.",
    )
    a.add_argument("description", help="One paragraph describing the repetitive task.")
    a.add_argument("--slug", help="Override the generated slug.")
    a.add_argument(
        "--force",
        action="store_true",
        help="Overwrite an existing automation/skill of the same name.",
    )
    a.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the dispatch prompt without invoking claude.",
    )
    a.set_defaults(func=cmd_add)

    sub.add_parser(
        "list",
        help="List automations with their build status and run count.",
    ).set_defaults(func=cmd_list)

    r = sub.add_parser(
        "run",
        help="Run a built automation. Archives inputs + outputs under runs/<ts>/.",
    )
    r.add_argument("name", help="Automation slug (see `frame list`).")
    r.add_argument(
        "--in",
        dest="input",
        action="append",
        metavar="PATH",
        help="Attach a file as input (CSV/JSON/PDF/.md/...). Repeatable.",
    )
    r.add_argument(
        "--image",
        action="append",
        metavar="PATH",
        help="Attach an image (PNG/JPG) as input. Repeatable. "
             "Claude reads images natively via the multimodal model.",
    )
    r.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the dispatch prompt without invoking claude.",
    )
    r.add_argument(
        "rest",
        nargs="*",
        help="Free-form text arguments passed to the skill.",
    )
    r.set_defaults(func=cmd_run)

    rf = sub.add_parser(
        "refine",
        help="Evolve an existing skill without changing its name or interface.",
    )
    rf.add_argument("name", help="Automation slug to refine.")
    rf.add_argument("refinement", help="Natural-language description of the change.")
    rf.add_argument(
        "--dry-run",
        action="store_true",
        help="Print the dispatch prompt without invoking claude.",
    )
    rf.set_defaults(func=cmd_refine)

    s = sub.add_parser("share", help="Stage + commit an automation for sharing.")
    s.add_argument("name")
    s.add_argument("-m", "--message", help="Override the default commit message.")
    s.set_defaults(func=cmd_share)

    u = sub.add_parser(
        "update",
        help="Pull the latest skills/agents from the remote and re-run setup.",
    )
    u.add_argument(
        "--force",
        action="store_true",
        help="Pull even if the working tree has uncommitted changes (discards them).",
    )
    u.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would happen without pulling.",
    )
    u.set_defaults(func=cmd_update)

    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
